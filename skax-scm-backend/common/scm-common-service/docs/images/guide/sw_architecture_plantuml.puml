@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho

rectangle "controller" as CONTROLLER {
  class "Controller" as C
  interface "ServicePort" as SP
  class "Request / Response DTO" as RD
}

rectangle "service" as SERVICE {
  class "Service" as S
  interface "RepositoryPort" as RP
}

rectangle "infrastructure" as INFRA {
  rectangle "mybatis" as MYBATIS {
    class "RepositoryMybatis\n(mapper)" as RMY
    class "Mapper DTO" as MD
  }
  class "PostgreSQL" as DB <<database>>
}

rectangle "domain" as DOMAIN {
  class "model" as M
}

CONTROLLER -right[hidden]-> SERVICE
SERVICE -right[hidden]-> INFRA
SERVICE -down[hidden]-> DOMAIN

C ..> SP : Use
SP ..> S
S ..> RP : Use
RP ..> RMY
C ..> RD : Use
RMY ..> MD : Use
RMY ..> DB : Use
S ..> M : Use

@enduml
